{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cornell Diary",
  "version": "1.0.0",
  "identifier": "com.deniz.cornelldiary",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cornell Diary",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Cornell note-taking for your daily diary.",
    "longDescription": "Offline-first, privacy-first personal diary built on Tauri 2 + React. Cornell-style layout with dynamic cue sections, summary, and quote.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
