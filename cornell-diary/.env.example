# Cornell Diary environment template.
# Copy to .env and adjust.

# --- Postgres migration + Cloud sync (FAZ 1+) ---
# Local Postgres (Docker container `diary_postgres`; see docker-compose.yml).
# Host port 5435 because 5432 is taken by another local project on this machine.
DATABASE_URL=postgres://diary_user:change_me_in_dev@127.0.0.1:5435/diary_db

# Cloud server (FAZ 2). Override at runtime via app_settings.
# Port 5001 because macOS Control Center / AirPlay Receiver holds *:5000.
CLOUD_URL=http://127.0.0.1:5001
CLOUD_WS_URL=ws://127.0.0.1:5001

# Sync (FAZ 2)
SYNC_INTERVAL_HOURS=1
NETWORK_PROBE_INTERVAL_SECONDS=30
DEVICE_LABEL_DEFAULT=Deniz-Macbook

# --- Android build-time injection (Yol Haritası 1.4) ---
# Tauri Android binaries don't inherit shell env at runtime, so this
# var is consumed by build.rs and forwarded into the binary via
# cargo:rustc-env. Set this to the laptop's LAN IP so the phone can
# reach Cloud over Wi-Fi:
# DIARY_CLOUD_URL=http://192.168.x.x:5001

# --- Observability + Faz 1/2 feature flags (placeholders) ---
# Faz 1.1: server-side merge strategy. lmw=last-write-wins (current);
# crdt=op-replay for text fields. Default lmw → no behaviour change.
SYNC_MERGE_STRATEGY=lmw
# Faz 1.3: Prometheus /metrics endpoint. Default off.
PROMETHEUS_ENABLED=false
# Faz 1.3: Sentry DSN. Empty → SDK no-op.
SENTRY_DSN=
# Faz 2.2: CRDT tombstone GC. Default off.
ENABLE_CRDT_GC=false
# Faz 3.1: where the WS broadcast bus lives. memory (default, single
# worker) or redis (multi-worker, requires Redis 7).
BROADCAST_BACKEND=memory

# Logging
RUST_LOG=cornell_diary=info,sqlx=warn

# One-time migration (FAZ 1.2 only; goes away after FAZ 1.3)
# Default macOS path; adjust on Linux/Windows.
SQLITE_LEGACY_PATH=/Users/ismaildeniz/Library/Application Support/com.deniz.cornelldiary/cornell_diary.db

# --- Frontend (existing) ---
# Future Jarvis integration. Not used today.
# VITE_USE_JARVIS=false
# VITE_JARVIS_URL=https://jarvis.local/api
# VITE_JARVIS_KEY=
